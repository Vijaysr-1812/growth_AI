generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// NEXTAUTH REQUIRED TABLES
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid()) 
  name          String?
  email         String?   @unique
  emailVerified DateTime? // Supabase callback or SQL Trigger will set this
  image         String?
  password      String?   // Hashed for credentials login
  
  // Profile Fields
  purpose              String?
  referralSource       String?
  company              String?
  role                 String?
  investmentExperience String?
  
  // REMOVED: verificationToken (Supabase manages this now)

  accounts      Account[]
  sessions      Session[]
  watchlists    Watchlist[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt // Add @default(now()) here
}

// NextAuth's internal table for Email Provider tokens. 
// You can keep this or remove it since Supabase is handling the verification links.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// NEXUS AI PLATFORM TABLES
// ==========================================

model Watchlist {
  id        String   @id @default(cuid())
  name      String   
  tickers   String[] 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}